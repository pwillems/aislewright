    "db:seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@aislewright/shared": "workspace:*",
    "dotenv": "^16.5.0",
    "fastify": "^5.3.3",
    "kysely": "^0.28.2",
    "pg": "^8.16.0",
    "zod": "^3.25.56"
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/pg": "^8.15.4",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
